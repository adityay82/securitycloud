# ─── CloudSec Environment Configuration ─────────────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-50+-character-secret-key-here-change-this!
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ── Database (PostgreSQL for production) ─────────────────────────────────────
DB_NAME=cloudsec_db
DB_USER=cloudsec_user
DB_PASSWORD=your-strong-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Email (SMTP for production OTP delivery) ──────────────────────────────────
# For development, leave EMAIL_BACKEND as console (OTP prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=cloudsecurity4@gmail.com
EMAIL_HOST_PASSWORD=mjbk daed antx pybd
DEFAULT_FROM_EMAIL=cloudsecurity4@gmail.com

# ── AWS S3 (set USE_S3=True to enable cloud storage) ─────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=cloudsec-encrypted-files
AWS_S3_REGION_NAME=us-east-1

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated list of trusted proxy IPs for X-Forwarded-For
TRUSTED_PROXIES=

# ── Session & Cookie ──────────────────────────────────────────────────────────
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
